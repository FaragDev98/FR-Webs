<!-- ui-system/Good.html -->
<div id="globalHeader">
  <header class="fr-header">
    <div class="header-inner">
      
      <!-- الشعار -->
      <a href="index.html" class="brand">
        <span class="brand-title">Fabrica Course</span>
        <div class="logo">
          <img src="../assets/logo.png" alt="logo">
        </div>
      </a>

      <!-- زر القائمة -->
      <div class="header-actions">
        <button id="menuToggle" class="btn-icon" aria-label="menu">🗂</button>
      </div>
    </div>
  </header>

  <!-- القائمة الجانبية -->
  <aside id="sideMenu" class="side-menu">
    <div class="side-header">
      <button id="closeMenu" class="btn-close">✖</button>
      <h2>القائمة</h2>
    </div>

    <nav class="side-links">
      <a href="../index.html">الرئيسية</a>
      <a href="../artic/index.html">المقالات</a>
      <a href="../lessons-page/index.html">الكورسات</a>
      <a href="../dev-english/index.html">الإنجليزي</a>
    </nav>
  </aside>
</div>

<script>
/* فتح القائمة */
document.addEventListener("click", (e) => {
  if (e.target.id === "menuToggle") {
    document.getElementById("sideMenu").classList.add("open");
  }
  if (e.target.id === "closeMenu") {
    document.getElementById("sideMenu").classList.remove("open");
  }
});
</script>
